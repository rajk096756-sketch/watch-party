# SMTP Configuration (For transactional emails - OTP, invoices, etc.)
# For production: Use real SMTP credentials (e.g., Gmail, SendGrid, AWS SES)
# For development: Leave as mock values to use Ethereal test account or console logging
# Gmail Example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-digit-app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Twilio SMS Configuration (For phone OTP verification)
# Get credentials from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Razorpay API Credentials (Leave empty to enable mock checkout validation)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Geo-IP Service Configuration (Optional - for real location detection)
# Get free API key from https://ipapi.co/ or use ipstack.com
GEOIP_API_KEY=
GEOIP_SERVICE=ipapi
