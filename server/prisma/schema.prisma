datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  phoneNumber           String?
  passwordHash          String
  username              String            @unique
  subscriptionPlan      String            @default("Free") // "Free", "Bronze", "Silver", "Gold"
  avatarUrl             String?
  themePreference       String            @default("system") // "system", "light", "dark"
  shareLocation         Boolean           @default(false)
  preferredLocale       String            @default("en")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  
  // Security
  deviceFingerprints    DeviceFingerprint[]
  loginLocations        LoginLocation[]
  otps                  OTP[]
  
  // Limits
  downloads             Download[]
  comments              Comment[]
  commentLikes          CommentLike[]
  commentReports        CommentReport[]
}

model DeviceFingerprint {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String
  createdAt   DateTime @default(now())
}

model LoginLocation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city      String
  state     String
  country   String
  createdAt DateTime @default(now())
}

model OTP {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Video {
  id          String     @id @default(uuid())
  title       String
  description String
  url         String
  thumbnail   String
  duration    Int        // in seconds
  downloads   Download[]
  createdAt   DateTime   @default(now())
}

model Download {
  id           String   @id @default(uuid())
  userId       String
  videoId      String
  downloadDate DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Comment {
  id           String          @id @default(uuid())
  content      String
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId      String
  createdAt    DateTime        @default(now())
  city         String?
  state         String?
  country      String?
  shareLocation Boolean        @default(false)
  isFlagged    Boolean         @default(false)
  
  likes        CommentLike[]
  reports      CommentReport[]
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  isLike    Boolean  // true for like, false for dislike
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model CommentReport {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}
